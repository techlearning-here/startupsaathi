# Copy to .env and fill. Do not commit .env.
# Set DEBUG=true to see JWT error details in 401 responses (e.g. "Signature verification failed")
DEBUG=false
SUPABASE_URL=https://xxx.supabase.co
# Backend must use service_role key (secret) so RLS is bypassed; do not use anon key here.
SUPABASE_KEY=eyJ...
# JWT Secret from Supabase: Project Settings → API → JWT Secret (only for legacy HS256)
SUPABASE_JWT_SECRET=your-jwt-secret
FRONTEND_URL=http://localhost:3000
